# Copy to .env and fill in real values for local development.

# Postgres connection string for the main DB (see docker-compose.yml for local defaults)
DATABASE_URL=postgres://postgres:password@localhost/iot_monitoring

# Secret used to sign JWTs
JWT_SECRET=change-me

# Optional: a signup with this exact email is granted the Admin role instead
# of the default Operator. There's no other API path to create an Admin.
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
